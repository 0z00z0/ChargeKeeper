<?xml version="1.0" encoding="utf-8"?>
<Application
    x:Class="ChargeKeeper.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:tb="using:H.NotifyIcon"
    RequestedTheme="Dark">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
            </ResourceDictionary.MergedDictionaries>

            <!-- ─────────────────────────────────────────────────────────────────────────────
                 ZeroZero Software studio CHROME palette + typeface (issue #23 rebrand).

                 These override the small set of WinUI theme brushes the app's chrome already
                 references ({ThemeResource TextFillColor…}, dividers/strokes, card surfaces and
                 the accent), so the Dashboard/Settings/History windows adopt the studio look with
                 no per-window edits. Values come verbatim from 0z0-design/design-language.md.

                 IMPORTANT — this is CHROME only. The product-functional colours (the battery
                 gauge tiers, tray icon and history series in Helpers/AppColors.cs +
                 GaugePalette.cs — SteelBlue/SageGreen/Terracotta/Amber) are ChargeKeeper's own
                 product identity and are deliberately NOT touched here.

                 The studio palette is DARK by design, and the Application forces RequestedTheme="Dark"
                 (above), so only the "Default" (dark) theme dictionary is ever selected. The old
                 "Light" dictionary carried an identical copy of these overrides (a workaround for a
                 user on the OS Light theme getting near-white studio text over light WinUI surfaces);
                 with the app pinned to Dark it is redundant and has been removed. -->
            <ResourceDictionary.ThemeDictionaries>
                <ResourceDictionary x:Key="Default">
                    <!-- Text -->
                    <SolidColorBrush x:Key="TextFillColorPrimaryBrush"   Color="#dde6f4"/>
                    <SolidColorBrush x:Key="TextFillColorSecondaryBrush" Color="#93a4bb"/>
                    <SolidColorBrush x:Key="TextFillColorTertiaryBrush"  Color="#64788f"/>
                    <SolidColorBrush x:Key="TextFillColorDisabledBrush"  Color="#45566a"/>
                    <!-- Hairlines / dividers / strokes -->
                    <SolidColorBrush x:Key="DividerStrokeColorDefaultBrush"  Color="#1a2840"/>
                    <SolidColorBrush x:Key="ControlStrokeColorDefaultBrush"  Color="#1a2840"/>
                    <SolidColorBrush x:Key="CardStrokeColorDefaultBrush"     Color="#1a2840"/>
                    <!-- Card / panel surfaces (SettingsCard, BatteryHealthPanel) -->
                    <SolidColorBrush x:Key="CardBackgroundFillColorDefaultBrush"   Color="#0e1620"/>
                    <SolidColorBrush x:Key="CardBackgroundFillColorSecondaryBrush" Color="#101a26"/>
                    <!-- Primary accent → studio teal (toggles, nav selection, focus, primary buttons).
                         The paired *Color* keys and SystemAccentColor* below MUST agree with these
                         brushes: some control visual-states (ToggleSwitch "on" fill, the RangeSelector
                         thumb/track, Button hover/pressed/checked) resolve the OS system accent COLOR
                         rather than the AccentFill brush, so overriding only the brushes left those
                         states painting the OS accent instead of studio teal. -->
                    <SolidColorBrush x:Key="AccentFillColorDefaultBrush"   Color="#27e0c8"/>
                    <SolidColorBrush x:Key="AccentFillColorSecondaryBrush" Color="#E627e0c8"/>
                    <SolidColorBrush x:Key="AccentFillColorTertiaryBrush"  Color="#CC27e0c8"/>
                    <!-- Paired accent *Color* keys (brush forms above) -->
                    <Color x:Key="AccentFillColorDefaultColor">#27e0c8</Color>
                    <Color x:Key="AccentFillColorSecondaryColor">#E627e0c8</Color>
                    <Color x:Key="AccentFillColorTertiaryColor">#CC27e0c8</Color>
                    <Color x:Key="AccentTextFillColorPrimaryColor">#27e0c8</Color>
                    <!-- System accent ramp → studio teal (39,224,200) with lighter/darker steps.
                         Drives accent visual-states that read SystemAccentColor* directly. -->
                    <Color x:Key="SystemAccentColor">#27e0c8</Color>
                    <Color x:Key="SystemAccentColorLight1">#52e6d3</Color>
                    <Color x:Key="SystemAccentColorLight2">#7decde</Color>
                    <Color x:Key="SystemAccentColorLight3">#a9f2e9</Color>
                    <Color x:Key="SystemAccentColorDark1">#1fb3a0</Color>
                    <Color x:Key="SystemAccentColorDark2">#178678</Color>
                    <Color x:Key="SystemAccentColorDark3">#105a50</Color>
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>

            <!-- Studio palette exposed as named brushes for explicit use in chrome XAML.
                 (design-language.md colour table). -->
            <SolidColorBrush x:Key="BrandBgBrush"     Color="#0a0f17"/>
            <SolidColorBrush x:Key="BrandBg2Brush"    Color="#0e1620"/>
            <SolidColorBrush x:Key="BrandBg3Brush"    Color="#101a26"/>
            <SolidColorBrush x:Key="BrandBorderBrush" Color="#1a2840"/>
            <SolidColorBrush x:Key="BrandTextBrush"   Color="#dde6f4"/>
            <SolidColorBrush x:Key="BrandMutedBrush"  Color="#64788f"/>
            <SolidColorBrush x:Key="BrandTealBrush"   Color="#27e0c8"/>
            <SolidColorBrush x:Key="BrandBlueBrush"   Color="#11a9d6"/>
            <SolidColorBrush x:Key="BrandPurpleBrush" Color="#7b8cff"/>
            <SolidColorBrush x:Key="BrandIndigoBrush" Color="#3f5be0"/>

            <!-- Brand typeface: Cascadia Mono. Reused from the shared ZeroZero.Brand.WinUI library,
                 which ships the .ttf as Content into this app's output under Assets\Fonts\ (same
                 file the shared About window references) — so it is NOT re-bundled here. Per
                 0z0-design: Cascadia Mono is the studio's UI/body/heading face; monospace is used
                 throughout the brand, not just for code. -->
            <FontFamily x:Key="BrandFont">ms-appx:///Assets/Fonts/CascadiaMono.ttf#Cascadia Mono</FontFamily>

            <!-- Default chrome typeface: applied to every TextBlock that has no explicit Style.
                 TextBlock has no control template, so an implicit style here is safe (it only sets
                 the font). Content strings in Buttons/ComboBoxes render through TextBlocks too, so
                 they pick this up as well. The keyed TextBlock styles below repeat the FontFamily
                 setter since a keyed style opts out of the implicit one. -->
            <Style TargetType="TextBlock">
                <Setter Property="FontFamily" Value="{StaticResource BrandFont}"/>
            </Style>

            <tb:TaskbarIcon
                x:Key="TrayIcon"
                ToolTipText="ChargeKeeper"
                NoLeftClickDelay="True"/>

            <!-- Shared stat-label / stat-value text styles (TODO #17 sub-item #3). The uppercase
                 caption LABEL (POWER / REMAINING / BATTERY HEALTH) and its VALUE below it were the
                 same inline TextBlock property sets pasted ~5 times across DashboardWindow,
                 BatteryHistoryWindow and BatteryHealthPanel. Centralised here so a tweak to the stat
                 typography happens once; per-instance bits (x:Name, Text/binding, Grid placement,
                 the health summary's TextWrapping) stay inline at each call site. Application-level
                 so every window and UserControl resolves them via StaticResource. -->
            <Style x:Key="StatLabelStyle" TargetType="TextBlock">
                <Setter Property="FontFamily" Value="{StaticResource BrandFont}"/>
                <Setter Property="FontSize" Value="10"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Foreground" Value="{ThemeResource TextFillColorTertiaryBrush}"/>
                <Setter Property="CharacterSpacing" Value="100"/>
            </Style>
            <Style x:Key="StatValueStyle" TargetType="TextBlock">
                <Setter Property="FontFamily" Value="{StaticResource BrandFont}"/>
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="Foreground" Value="{ThemeResource TextFillColorPrimaryBrush}"/>
            </Style>

            <!-- SettingsWindow (TODO #19) section + sub-section headers. Same extraction rationale
                 as the stat styles above: these TextBlock property sets were pasted per-section.
                 SectionHeaderStyle carries the uniform bottom margin; SubHeaderStyle leaves Margin
                 inline since it varies between the first sub-header and the later ones. -->
            <Style x:Key="SectionHeaderStyle" TargetType="TextBlock">
                <Setter Property="FontFamily" Value="{StaticResource BrandFont}"/>
                <Setter Property="FontSize" Value="16"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Margin" Value="0,0,0,4"/>
            </Style>
            <Style x:Key="SubHeaderStyle" TargetType="TextBlock">
                <Setter Property="FontFamily" Value="{StaticResource BrandFont}"/>
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Opacity" Value="0.85"/>
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
