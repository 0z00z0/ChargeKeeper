<?xml version="1.0" encoding="utf-8"?>
<Application
    x:Class="ChargeKeeper.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:tb="using:H.NotifyIcon">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
            </ResourceDictionary.MergedDictionaries>

            <tb:TaskbarIcon
                x:Key="TrayIcon"
                ToolTipText="ChargeKeeper"
                NoLeftClickDelay="True"/>

            <!-- Shared stat-label / stat-value text styles (TODO #17 sub-item #3). The uppercase
                 caption LABEL (POWER / REMAINING / BATTERY HEALTH) and its VALUE below it were the
                 same inline TextBlock property sets pasted ~5 times across DashboardWindow,
                 BatteryHistoryWindow and BatteryHealthPanel. Centralised here so a tweak to the stat
                 typography happens once; per-instance bits (x:Name, Text/binding, Grid placement,
                 the health summary's TextWrapping) stay inline at each call site. Application-level
                 so every window and UserControl resolves them via StaticResource. -->
            <Style x:Key="StatLabelStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="10"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Foreground" Value="{ThemeResource TextFillColorTertiaryBrush}"/>
                <Setter Property="CharacterSpacing" Value="100"/>
            </Style>
            <Style x:Key="StatValueStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="Foreground" Value="{ThemeResource TextFillColorPrimaryBrush}"/>
            </Style>

            <!-- SettingsWindow (TODO #19) section + sub-section headers. Same extraction rationale
                 as the stat styles above: these TextBlock property sets were pasted per-section.
                 SectionHeaderStyle carries the uniform bottom margin; SubHeaderStyle leaves Margin
                 inline since it varies between the first sub-header and the later ones. -->
            <Style x:Key="SectionHeaderStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="16"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Margin" Value="0,0,0,4"/>
            </Style>
            <Style x:Key="SubHeaderStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Opacity" Value="0.85"/>
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
