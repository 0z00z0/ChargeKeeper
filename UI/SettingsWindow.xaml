<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="ChargeKeeper.UI.SettingsWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="using:ChargeKeeper.UI"
    xmlns:controls="using:CommunityToolkit.WinUI.Controls"
    mc:Ignorable="d">

    <!-- TODO #19: a proper titled, resizable, taskbar-visible window (default WinUI3 chrome — NOT
         WindowChrome.ApplyPopup, which auto-dismisses on focus loss and would close this window
         while the user is mid-edit, e.g. typing a broker password). Mica BaseAlt, same as every
         other window in this app. -->
    <Window.SystemBackdrop>
        <MicaBackdrop Kind="BaseAlt" />
    </Window.SystemBackdrop>

    <NavigationView x:Name="Nav"
                     IsSettingsVisible="False"
                     IsBackButtonVisible="Collapsed"
                     IsTabStop="False"
                     PaneDisplayMode="Left"
                     SelectionChanged="OnNavSelectionChanged">

        <!-- Issue #51: let the Mica BaseAlt backdrop show through the NavigationView instead of the
             control painting its own lighter-grey pane/top strip over it. Overriding these brushes
             to Transparent removes the grey top bar (the region around the pane toggle) that
             regressed after the #23 Dark-theme change, and keeps the pane and content consistent
             with every other window. The selected-item teal highlight is a SEPARATE brush
             (NavigationViewSelectionIndicatorForeground / item background) and is untouched. -->
        <NavigationView.Resources>
            <SolidColorBrush x:Key="NavigationViewDefaultPaneBackground" Color="Transparent"/>
            <SolidColorBrush x:Key="NavigationViewExpandedPaneBackground" Color="Transparent"/>
            <SolidColorBrush x:Key="NavigationViewTopPaneBackground" Color="Transparent"/>
            <SolidColorBrush x:Key="NavigationViewContentBackground" Color="Transparent"/>
            <SolidColorBrush x:Key="NavigationViewContentGridBorderBrush" Color="Transparent"/>
            <Thickness x:Key="NavigationViewContentGridBorderThickness">0</Thickness>

            <!-- Enlarge the bespoke two-tone nav icons (#52). The left-pane
                 NavigationViewItemPresenter template wraps the item Icon in a Viewbox whose Height
                 is bound to this theme resource (default 16px), so the ImageIcon Width/Height="28"
                 below was still being scaled down to ~16px. Overriding this single resource is the
                 least-invasive fix — it enlarges the icon box to ~28px without touching the item
                 template, label alignment, or collapsed/compact pane behaviour. Adjust this one
                 number if the size needs tuning after an on-screen check. -->
            <x:Double x:Key="NavigationViewItemOnLeftIconBoxHeight">28</x:Double>
        </NavigationView.Resources>

        <!-- #52: bespoke two-tone nav icons (steel outline + sage/terracotta accents), shipped as
             SVG assets and shown via ImageIcon/SvgImageSource — two-tone can't be a single-colour
             PathIcon. -->
        <NavigationView.MenuItems>
            <NavigationViewItem Content="General"         Tag="General">
                <NavigationViewItem.Icon><ImageIcon Source="ms-appx:///Assets/nav/general.svg" Width="28" Height="28"/></NavigationViewItem.Icon>
            </NavigationViewItem>
            <NavigationViewItem Content="Smart Charge"     Tag="SmartCharge">
                <NavigationViewItem.Icon><ImageIcon Source="ms-appx:///Assets/nav/smart-charge.svg" Width="28" Height="28"/></NavigationViewItem.Icon>
            </NavigationViewItem>
            <NavigationViewItem Content="Notifications"    Tag="Notifications">
                <NavigationViewItem.Icon><ImageIcon Source="ms-appx:///Assets/nav/notifications.svg" Width="28" Height="28"/></NavigationViewItem.Icon>
            </NavigationViewItem>
            <NavigationViewItem Content="Network"          Tag="Network">
                <NavigationViewItem.Icon><ImageIcon Source="ms-appx:///Assets/nav/network.svg" Width="28" Height="28"/></NavigationViewItem.Icon>
            </NavigationViewItem>
            <NavigationViewItem Content="MQTT"             Tag="HomeAssistant">
                <NavigationViewItem.Icon><ImageIcon Source="ms-appx:///Assets/nav/mqtt.svg" Width="28" Height="28"/></NavigationViewItem.Icon>
            </NavigationViewItem>
            <!-- #45: an Appearance section (a dead "Use new styling" toggle) was removed; restore a
                 nav item here — icon asset Assets/nav/appearance.svg is retained — when there's a
                 real styling setting to expose. -->
            <NavigationViewItem Content="About"            Tag="About">
                <NavigationViewItem.Icon><ImageIcon Source="ms-appx:///Assets/nav/about.svg" Width="28" Height="28"/></NavigationViewItem.Icon>
            </NavigationViewItem>
        </NavigationView.MenuItems>

        <!-- Issue #51: subtle app-identity footer, bottom-left of the pane — logo + name + the
             running app version. VersionText is filled in the constructor from AppInfo.Version (the
             same assembly-version source the About box uses), never hard-coded. -->
        <NavigationView.PaneFooter>
            <StackPanel Margin="0,4,0,4">
                <Border Height="1" Margin="16,0,16,8"
                        Background="{ThemeResource DividerStrokeColorDefaultBrush}"/>
                <StackPanel Orientation="Horizontal" Spacing="8"
                            Margin="16,4,16,12" VerticalAlignment="Center">
                    <Image Source="ms-appx:///Assets/AppIcon.png"
                           Width="36" Height="36" VerticalAlignment="Center"/>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="ChargeKeeper" FontSize="12"
                                   FontFamily="{StaticResource BrandFont}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <TextBlock x:Name="VersionText" FontSize="11"
                                   Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                    </StackPanel>
                </StackPanel>
            </StackPanel>
        </NavigationView.PaneFooter>

        <ScrollViewer Padding="20,8,20,12" VerticalScrollBarVisibility="Auto">
            <Grid>

                <!-- Density (issue #22): the SettingsCards are the same control PowerToys Settings
                     uses, so their intrinsic density already matches. This lightweight-styling
                     override trims the default 68px card floor so single-line rows (e.g. the Home
                     Assistant broker fields) don't reserve extra vertical space; description-bearing
                     cards grow past it as before. Additive resource — a harmless no-op if a toolkit
                     version stops honouring the key. Scoped to this Grid so it covers every card
                     (including the code-built preset / network rows nested below). -->
                <Grid.Resources>
                    <x:Double x:Key="SettingsCardMinHeight">52</x:Double>
                </Grid.Resources>

                <!-- ── General ─────────────────────────────────────────────────── -->
                <StackPanel x:Name="GeneralPanel" Spacing="4">
                    <TextBlock Text="General" Style="{StaticResource SectionHeaderStyle}"/>

                    <controls:SettingsCard Header="Startup delay"
                                            Description="Seconds to wait after sign-in before ChargeKeeper initialises (0 = no delay). Keeps the app off the critical sign-in path.">
                        <ComboBox x:Name="StartupDelayCombo" MinWidth="140"
                                  SelectionChanged="OnStartupDelayChanged"/>
                    </controls:SettingsCard>

                    <controls:SettingsCard Header="Tray icon style"
                                            Description="How the battery level is drawn in the system tray.">
                        <ComboBox x:Name="IconModeCombo" MinWidth="160" SelectionChanged="OnIconModeChanged">
                            <ComboBoxItem Content="Arc gauge"/>
                            <ComboBoxItem Content="Numeric %"/>
                        </ComboBox>
                    </controls:SettingsCard>

                    <controls:SettingsCard Header="History graph range"
                                            Description="Default time span shown in the battery history graph.">
                        <ComboBox x:Name="GraphScaleCombo" MinWidth="160" SelectionChanged="OnGraphScaleChanged">
                            <ComboBoxItem Content="15 minutes"/>
                            <ComboBoxItem Content="1 hour"/>
                            <ComboBoxItem Content="6 hours"/>
                            <ComboBoxItem Content="12 hours"/>
                            <ComboBoxItem Content="1 day"/>
                            <ComboBoxItem Content="1 week"/>
                            <ComboBoxItem Content="14 days"/>
                        </ComboBox>
                    </controls:SettingsCard>

                    <controls:SettingsCard Header="Downtime gap threshold"
                                            Description="How long a hole in the sample timeline must be before the history graph shows it as a break (0 = none).">
                        <ComboBox x:Name="DowntimeGapCombo" MinWidth="140"
                                  SelectionChanged="OnDowntimeGapChanged"/>
                    </controls:SettingsCard>

                    <!-- Advanced: the two settings-file actions that used to live in the tray menu
                         (TODO #28 — "Open settings folder" / "Reload settings from file"). -->
                    <TextBlock Text="Advanced" Style="{StaticResource SubHeaderStyle}" Margin="0,8,0,4"/>
                    <controls:SettingsCard Header="Settings file"
                                            Description="ChargeKeeper stores its configuration in settings.json. Reload picks up changes made outside the app (a manual edit, or a file synced in from another machine).">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button x:Name="OpenSettingsFolderBtn" Content="Open settings folder" Click="OnOpenSettingsFolder"/>
                            <Button x:Name="ReloadSettingsBtn" Content="Reload settings from file" Click="OnReloadSettings"/>
                        </StackPanel>
                    </controls:SettingsCard>
                </StackPanel>

                <!-- ── Smart Charge (presets) ──────────────────────────────────── -->
                <StackPanel x:Name="SmartChargePanel" Spacing="4" Visibility="Collapsed">
                    <TextBlock Text="Smart Charge" Style="{StaticResource SectionHeaderStyle}"/>

                    <TextBlock Text="Presets" Style="{StaticResource SubHeaderStyle}" Margin="0,0,0,4"/>
                    <StackPanel x:Name="PresetsListPanel" Spacing="4"/>
                    <Button x:Name="AddPresetBtn" Content="Add preset" Click="OnAddPreset" Margin="0,4,0,12"/>

                    <controls:SettingsCard Header="Unknown-network preset"
                                            Description="Preset to apply when the current network matches none of the profiles in the Network section, and network profiles are enabled.">
                        <ComboBox x:Name="UnknownPresetCombo" MinWidth="200" SelectionChanged="OnUnknownPresetChanged"/>
                    </controls:SettingsCard>
                </StackPanel>

                <!-- ── Notifications ────────────────────────────────────────────── -->
                <StackPanel x:Name="NotificationsPanel" Spacing="4" Visibility="Collapsed">
                    <TextBlock Text="Notifications" Style="{StaticResource SectionHeaderStyle}"/>

                    <controls:SettingsCard Header="Low battery warning"
                                            Description="Notify when the battery drops to this level while discharging.">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <ComboBox x:Name="LowBattPctCombo" MinWidth="110"
                                      SelectionChanged="OnLowBattPctChanged"/>
                            <ToggleSwitch x:Name="LowBattEnabledToggle" OnContent="On" OffContent="Off" Toggled="OnLowBattEnabledToggled"/>
                        </StackPanel>
                    </controls:SettingsCard>

                    <controls:SettingsCard Header="Overnight-drain warning"
                                            Description="Notify when the battery loses charge faster than this rate across a detected downtime gap.">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <ComboBox x:Name="DrainPctPerHourCombo" MinWidth="110"
                                      SelectionChanged="OnDrainPctPerHourChanged"/>
                            <ToggleSwitch x:Name="DrainEnabledToggle" OnContent="On" OffContent="Off" Toggled="OnDrainEnabledToggled"/>
                        </StackPanel>
                    </controls:SettingsCard>
                </StackPanel>

                <!-- ── Network ──────────────────────────────────────────────────── -->
                <StackPanel x:Name="NetworkPanel" Spacing="4" Visibility="Collapsed">
                    <TextBlock Text="Network" Style="{StaticResource SectionHeaderStyle}"/>

                    <controls:SettingsCard Header="Enable network profiles"
                                            Description="Automatically apply a preset when the detected network location changes. Matching is by adapter MAC address and/or IP subnet only — never by Wi-Fi network name.">
                        <ToggleSwitch x:Name="NetworkEnabledToggle" OnContent="On" OffContent="Off" Toggled="OnNetworkEnabledToggled"/>
                    </controls:SettingsCard>

                    <controls:SettingsCard Header="Current network">
                        <TextBlock x:Name="CurrentNetworkText" Text="—" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    </controls:SettingsCard>

                    <TextBlock Text="Profiles" Style="{StaticResource SubHeaderStyle}" Margin="0,8,0,4"/>
                    <StackPanel x:Name="NetworkRulesListPanel" Spacing="4"/>
                    <Button x:Name="AddNetworkRuleBtn" Content="Add profile for this network…" Click="OnAddNetworkRule" Margin="0,4,0,0"/>
                </StackPanel>

                <!-- ── MQTT (section label; the publisher defaults to HA's discovery convention) ── -->
                <StackPanel x:Name="HomeAssistantPanel" Spacing="4" Visibility="Collapsed">
                    <TextBlock Text="MQTT" Style="{StaticResource SectionHeaderStyle}"/>

                    <controls:SettingsCard Header="Publish to MQTT"
                                            Description="Publishes battery/charge state to an MQTT broker using the standard MQTT auto-discovery convention. Applies immediately.">
                        <ToggleSwitch x:Name="HaEnabledToggle" OnContent="On" OffContent="Off" Toggled="OnHaEnabledToggled"/>
                    </controls:SettingsCard>

                    <TextBlock Text="Broker" Style="{StaticResource SubHeaderStyle}" Margin="0,8,0,4"/>
                    <TextBlock Text="Broker fields below are staged locally and only take effect when you click Apply — so the MQTT connection reconnects once per Apply, not per keystroke."
                               TextWrapping="Wrap" FontSize="11" Opacity="0.7" Margin="0,0,0,8"/>

                    <controls:SettingsCard Header="Host">
                        <TextBox x:Name="HaHostBox" MinWidth="220" PlaceholderText="e.g. 10.0.20.22"/>
                    </controls:SettingsCard>
                    <controls:SettingsCard Header="Port">
                        <NumberBox x:Name="HaPortBox" Minimum="1" Maximum="65535" SpinButtonPlacementMode="Hidden" MinWidth="120"/>
                    </controls:SettingsCard>
                    <controls:SettingsCard Header="Username" Description="Leave blank for an anonymous broker.">
                        <TextBox x:Name="HaUsernameBox" MinWidth="220"/>
                    </controls:SettingsCard>
                    <controls:SettingsCard Header="Password" Description="Leave blank for an anonymous broker. Never logged.">
                        <PasswordBox x:Name="HaPasswordBox" MinWidth="220"/>
                    </controls:SettingsCard>
                    <controls:SettingsCard Header="Use TLS" Description="Broker port is usually 8883 when enabled.">
                        <ToggleSwitch x:Name="HaTlsToggle" OnContent="On" OffContent="Off"/>
                    </controls:SettingsCard>
                    <controls:SettingsCard Header="Discovery prefix" Description="The MQTT auto-discovery prefix your broker/consumer expects (default: homeassistant).">
                        <TextBox x:Name="HaPrefixBox" MinWidth="220"/>
                    </controls:SettingsCard>

                    <StackPanel Orientation="Horizontal" Spacing="12" Margin="0,8,0,0">
                        <Button x:Name="HaApplyBtn" Content="Apply" Click="OnHaApplyClicked"/>
                        <TextBlock x:Name="HaAppliedText" Text="Applied." VerticalAlignment="Center"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   Visibility="Collapsed"/>
                    </StackPanel>
                    <TextBlock x:Name="HaBrokerStatusText" Text="Broker: not set" Margin="0,8,0,0"
                               FontSize="11" Opacity="0.7"/>
                </StackPanel>

                <!-- #45: the Appearance section (a single dead "Use new styling" toggle) was
                     removed; a real Appearance panel can be reinstated here later. -->

                <!-- ── About (#59) ─────────────────────────────────────────────── -->
                <StackPanel x:Name="AboutPanel" Spacing="4" Visibility="Collapsed">
                    <TextBlock Text="About" Style="{StaticResource SectionHeaderStyle}"/>

                    <controls:SettingsCard Header="ChargeKeeper"
                                            Description="Keeps your laptop battery healthy — charge limits, a live battery gauge and smart standby control from the system tray. Made by ZeroZero Software.">
                        <controls:SettingsCard.HeaderIcon>
                            <ImageIcon Source="ms-appx:///Assets/AppIcon.png" Width="40" Height="40"/>
                        </controls:SettingsCard.HeaderIcon>
                        <Button x:Name="AboutButton" Content="About ChargeKeeper" Click="OnAboutClicked"/>
                    </controls:SettingsCard>
                </StackPanel>

            </Grid>
        </ScrollViewer>
    </NavigationView>
</Window>
