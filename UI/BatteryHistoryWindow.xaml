<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="ChargeKeeper.UI.BatteryHistoryWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="using:ChargeKeeper.UI"
    mc:Ignorable="d">

    <Window.SystemBackdrop>
        <MicaBackdrop Kind="BaseAlt" />
    </Window.SystemBackdrop>

    <!-- A frameless, resizable, close-on-blur window (DashboardWindow-style chrome, just bigger)
         hosting the same graph control — "Expand" already got the user here, so ShowExpandButton
         is off (hides the corner glyph and disables double-click-to-expand). -->
    <Grid Padding="20,16,20,20">
        <local:BatteryHistoryGraphControl x:Name="HistoryGraph" ShowExpandButton="False"/>
    </Grid>
</Window>
