<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="LenovoTray.UI.BatteryHistoryWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="using:LenovoTray.UI"
    mc:Ignorable="d">

    <Window.SystemBackdrop>
        <MicaBackdrop Kind="BaseAlt" />
    </Window.SystemBackdrop>

    <!-- A normal, resizable window (unlike DashboardWindow's borderless auto-hide popup) hosting
         the same graph control — "Expand" already got the user here, so ShowExpandButton is off. -->
    <Grid Padding="20,16,20,20">
        <local:BatteryHistoryGraphControl x:Name="HistoryGraph" ShowExpandButton="False"/>
    </Grid>
</Window>
