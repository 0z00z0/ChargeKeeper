<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="ChargeKeeper.UI.BatteryHealthPanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <!-- Battery health / degradation panel (TODO #24): a separate, slow-timescale section below
         the main SoC/Power graph — deliberately NOT folded into that graph, whose two Y-axes
         already cover a completely different (minutes-to-days) scale, and whose gap-collapsing
         x-axis would misrepresent a value that changes over months. Collapses to a single
         "gathering data" line until at least two daily samples exist. -->
    <!-- Studio card surface (CardBackgroundFillColorDefaultBrush is remapped to the studio bg2 in
         App.xaml) with a hairline studio border, so this health card matches the Settings cards. -->
    <Border CornerRadius="12"
            Padding="16,12"
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="1">
        <Grid RowSpacing="8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="90"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="BATTERY HEALTH"
                       Style="{StaticResource StatLabelStyle}"/>

            <TextBlock x:Name="SummaryText" Grid.Row="1"
                       Text="Gathering data…"
                       Style="{StaticResource StatValueStyle}"
                       TextWrapping="Wrap"/>

            <!-- Solid line = actual logged FullChargeCapacity; dashed continuation = a simple
                 linear-trend projection. Built in code (TrendCanvas.Children) since the data is
                 dynamic; SizeChanged re-renders on resize like the main graph's canvas does. -->
            <Canvas x:Name="TrendCanvas" Grid.Row="2"
                    Background="Transparent"
                    SizeChanged="OnCanvasSizeChanged"/>
        </Grid>
    </Border>
</UserControl>
