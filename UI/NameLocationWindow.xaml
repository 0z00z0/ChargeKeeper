<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="ChargeKeeper.UI.NameLocationWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Window.SystemBackdrop>
        <MicaBackdrop Kind="BaseAlt" />
    </Window.SystemBackdrop>

    <!-- "Name location" step (TODO #31) when adding a network-profile configuration for the
         currently-detected network. Same small always-on-top bordered-no-titlebar chrome as
         AboutWindow, just with a text-input step instead of static content. -->
    <Grid x:Name="Root" Padding="16,14,16,14" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Name this network location"
                   FontSize="13" FontWeight="SemiBold"
                   Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>

        <TextBox x:Name="NameBox" Grid.Row="1" FontSize="13"/>

        <Grid Grid.Row="2" ColumnSpacing="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Button x:Name="CancelBtn" Grid.Column="0" Content="Cancel" HorizontalAlignment="Stretch"/>
            <Button x:Name="OkBtn"     Grid.Column="1" Content="Save"   HorizontalAlignment="Stretch"/>
        </Grid>
    </Grid>
</Window>
