<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="ChargeKeeper.UI.DashboardWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="using:ChargeKeeper.UI"
    xmlns:controls="using:CommunityToolkit.WinUI.Controls"
    mc:Ignorable="d">

    <Window.SystemBackdrop>
        <MicaBackdrop Kind="BaseAlt" />
    </Window.SystemBackdrop>

    <!-- No fixed Width: the grid fills the window, which is sized in code per monitor DPI.
         The window height is measured from this grid (PlaceWindow), so rows can appear/disappear
         without any hard-coded height constants. -->
    <Grid x:Name="RootGrid" Padding="20,16,20,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- 0: Header -->
            <RowDefinition Height="Auto"/>  <!-- 1: Gauge + stats -->
            <RowDefinition Height="Auto"/>  <!-- 2: History graph (time-scale selector + sparkline) -->
            <RowDefinition Height="Auto"/>  <!-- 3: Separator -->
            <RowDefinition Height="Auto"/>  <!-- 4: Status badges -->
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8"
                    VerticalAlignment="Center" Margin="0,0,0,14">
            <Image Source="ms-appx:///Assets/AppIcon.png"
                   Width="18" Height="18" VerticalAlignment="Center"/>
            <TextBlock Text="ChargeKeeper"
                       FontSize="13"
                       FontWeight="SemiBold"
                       VerticalAlignment="Center"
                       Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
        </StackPanel>

        <!-- Battery gauge section: gauge left, stats right filling remaining width -->
        <Grid Grid.Row="1" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Circular arc gauge -->
            <Grid Grid.Column="0" Width="100" Height="100" Margin="0,0,16,0">
                <!-- Background arc (track) -->
                <Canvas Width="100" Height="100">
                    <Path x:Name="GaugeTrack"
                          Stroke="{ThemeResource ControlStrokeColorDefaultBrush}"
                          StrokeThickness="10"
                          StrokeStartLineCap="Round"
                          StrokeEndLineCap="Round"
                          Canvas.Left="0" Canvas.Top="0"/>
                    <Path x:Name="GaugeFill"
                          StrokeThickness="10"
                          StrokeStartLineCap="Round"
                          StrokeEndLineCap="Round"
                          Canvas.Left="0" Canvas.Top="0"/>
                    <!-- Charge threshold tick markers. Strokes (ticks AND the fill above) are
                         assigned in code-behind from the shared palette — ticks get
                         AppColors.HistoryLimitBrush (Terracotta) so the "charge limit" concept
                         reads as one colour everywhere; hex literals here had to be hand-synced
                         and once drifted. -->
                    <Path x:Name="GaugeStartTick"
                          StrokeThickness="2.5"
                          StrokeStartLineCap="Round"
                          StrokeEndLineCap="Round"
                          Canvas.Left="0" Canvas.Top="0"
                          Visibility="Collapsed"
                          Opacity="0.9"/>
                    <Path x:Name="GaugeStopTick"
                          StrokeThickness="2.5"
                          StrokeStartLineCap="Round"
                          StrokeEndLineCap="Round"
                          Canvas.Left="0" Canvas.Top="0"
                          Visibility="Collapsed"
                          Opacity="0.9"/>
                </Canvas>
                <!-- Percentage + a compact status glyph in the centre. The glyph (▲ charging /
                     ● idle / ▼ discharging) replaces the old status word, which was too wide and
                     touched the arc. Colour conveys state and is set in code. -->
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="-3">
                    <TextBlock x:Name="BatteryPercentText"
                               Text="--"
                               FontSize="23"
                               FontWeight="Bold"
                               HorizontalAlignment="Center"
                               Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                    <TextBlock x:Name="StatusGlyph"
                               Text="●"
                               FontSize="18"
                               HorizontalAlignment="Center"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                </StackPanel>
            </Grid>

            <!-- Right side stats -->
            <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="6">
                <StackPanel Spacing="2">
                    <TextBlock Text="POWER" Style="{StaticResource StatLabelStyle}"/>
                    <TextBlock x:Name="PowerSourceText"
                               Text="—"
                               Style="{StaticResource StatValueStyle}"/>
                </StackPanel>
                <StackPanel Spacing="2">
                    <TextBlock Text="REMAINING" Style="{StaticResource StatLabelStyle}"/>
                    <TextBlock x:Name="TimeRemainingText"
                               Text="—"
                               Style="{StaticResource StatValueStyle}"/>
                </StackPanel>
            </StackPanel>
        </Grid>

        <!-- Battery history graph + its time-scale ("period") controls — extracted into
             BatteryHistoryGraphControl so the exact same graph can also be hosted in the bigger,
             resizable BatteryHistoryWindow pop-out (opened via this control's "Expand" button)
             without duplicating the drawing code. PlotAreaHeight pins the plot canvas to the same
             126px it always had here, keeping this popup's measured size unchanged. -->
        <local:BatteryHistoryGraphControl x:Name="HistoryGraph"
                                           Grid.Row="2"
                                           Margin="0,0,0,12"
                                           PlotAreaHeight="126"/>

        <!-- Separator -->
        <Border Grid.Row="3"
                Height="1"
                Background="{ThemeResource DividerStrokeColorDefaultBrush}"
                Margin="0,0,0,12"/>

        <!-- Status badges -->
        <StackPanel Grid.Row="4" Spacing="8">

            <!-- Smart Charge badge -->
            <Border x:Name="SmartChargeBadge"
                    CornerRadius="6"
                    Padding="10,8">
                <StackPanel Spacing="0">
                    <!-- Header row: title + indicator dot -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Spacing="1">
                            <TextBlock Text="Smart Charge"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="{ThemeResource TextFillColorPrimaryBrush}">
                                <!-- Rich tooltip: a bold one-line summary, then a longer plain-
                                     language explanation — a plain-string ToolTip can't carry two
                                     font weights, so this uses an explicit ToolTip/StackPanel
                                     instead. MaxWidth keeps the paragraph from stretching edge to
                                     edge before it wraps. -->
                                <ToolTipService.ToolTip>
                                    <ToolTip>
                                        <StackPanel MaxWidth="280" Spacing="6">
                                            <TextBlock Text="Stops charging once your battery reaches your chosen limit, so it doesn't sit at 100% all day."
                                                       FontWeight="SemiBold"
                                                       FontSize="13"
                                                       TextWrapping="Wrap"/>
                                            <TextBlock TextWrapping="Wrap" FontSize="12" Opacity="0.85">
                                                Batteries wear out fastest when kept fully charged for long periods — the chemistry inside degrades quicker at high charge levels, especially while powered and warm at the same time, like a laptop plugged in at a desk. Smart Charge keeps your battery in a gentler middle range instead, which can meaningfully extend how many years it lasts before you notice shorter runtime. Need a full charge before a trip? Use "Charge to 100% once" below — it lifts the limit for a single charge and switches back automatically.
                                            </TextBlock>
                                        </StackPanel>
                                    </ToolTip>
                                </ToolTipService.ToolTip>
                            </TextBlock>
                            <TextBlock x:Name="SmartChargeDetailText"
                                       Text="—"
                                       FontSize="11"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        </StackPanel>
                        <Border Grid.Column="1"
                                x:Name="SmartChargeIndicator"
                                Width="8" Height="8"
                                CornerRadius="4"
                                VerticalAlignment="Center"/>
                    </Grid>

                    <!-- Threshold range — visible when Smart Charge is capable and enabled.
                         Changes auto-apply (debounced); there is no Apply button. A single
                         dual-thumb RangeSelector (CommunityToolkit.WinUI.Controls, MIT license —
                         see README external-libraries table) replaces the old two separate
                         sliders: Start% on the left, Stop% on the right of the same track, so the
                         relationship between them ("charge between X% and Y%") reads as one
                         control instead of two independent ones. Minimum/Maximum/StepFrequency
                         are set in code-behind (ConfigureThresholdRange) — assigning them via
                         XAML throws a XamlParseException on this Windows App SDK build (same
                         issue the old Slider.Minimum had). -->
                    <StackPanel x:Name="ThresholdSliders"
                                Spacing="0"
                                Margin="0,6,0,0"
                                Visibility="Collapsed">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="34"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="34"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" x:Name="StartValueText"
                                       FontSize="11" VerticalAlignment="Center"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            <controls:RangeSelector Grid.Column="1" x:Name="ThresholdRange"
                                    Height="28"
                                    ValueChanged="OnThresholdRangeChanged"/>
                            <TextBlock Grid.Column="2" x:Name="StopValueText"
                                       FontSize="11" VerticalAlignment="Center"
                                       HorizontalAlignment="Right"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        </Grid>
                    </StackPanel>

                    <!-- One-shot "charge to 100% once" (travel override). Visible whenever Smart
                         Charge is capable so it can also be cancelled while active. -->
                    <Button x:Name="TravelOverrideButton"
                            Content="🔝  Charge to 100 % once"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Center"
                            FontSize="11"
                            Padding="8,4"
                            Margin="0,8,0,0"
                            Visibility="Collapsed"
                            Click="OnTravelOverrideButton"/>
                </StackPanel>
            </Border>

            <!-- Smart Standby badge -->
            <Border x:Name="SmartStandbyBadge"
                    CornerRadius="6"
                    Padding="10,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Spacing="1">
                        <TextBlock Text="Smart Standby"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="{ThemeResource TextFillColorPrimaryBrush}">
                            <ToolTipService.ToolTip>
                                <ToolTip>
                                    <StackPanel MaxWidth="280" Spacing="6">
                                        <TextBlock Text="Puts your laptop into a deeper sleep after a while of inactivity, instead of the shallow sleep Windows uses by default."
                                                   FontWeight="SemiBold"
                                                   FontSize="13"
                                                   TextWrapping="Wrap"/>
                                        <TextBlock TextWrapping="Wrap" FontSize="12" Opacity="0.85">
                                            Windows' default "Modern Standby" keeps parts of your laptop lightly active even with the lid closed, so it can check for notifications and updates in the background — convenient, but it slowly drains the battery the whole time, even in a closed bag. Smart Standby schedules a deeper, fully-off sleep once the laptop has been idle for a while, so it loses much less charge overnight or in a bag. It only changes what happens during idle standby — sleeping manually, like closing the lid for a quick break, is unaffected.
                                        </TextBlock>
                                    </StackPanel>
                                </ToolTip>
                            </ToolTipService.ToolTip>
                        </TextBlock>
                        <TextBlock x:Name="SmartStandbyDetailText"
                                   Text="—"
                                   FontSize="11"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    </StackPanel>
                    <Border Grid.Column="1"
                            x:Name="SmartStandbyIndicator"
                            Width="8" Height="8"
                            CornerRadius="4"
                            VerticalAlignment="Center"/>
                </Grid>
            </Border>
        </StackPanel>

    </Grid>
</Window>
