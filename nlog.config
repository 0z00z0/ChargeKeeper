<?xml version="1.0" encoding="utf-8"?>
<!--
  The app's only forensic trail: %AppData%\ChargeKeeper\app.log. Retention and size live HERE, not
  in code, so they can be changed on an installed machine without a rebuild.

  Loaded automatically by NLog from beside the exe (see Services/AppLog.cs). If this file is missing
  or unparseable, AppLog falls back to an EQUIVALENT config built in code rather than logging
  nothing — the reasoning is in AppLog's remarks.
-->
<nlog xmlns="http://www.nlog-project.org/schemas/NLog.xsd"
      xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      internalLogLevel="Off">

  <targets>
    <!--
      Two settings here are the successor to the FileShare fix that #34 ("AppLog silently drops
      lines") bought with real debugging time, and NEITHER is decoration. Measured on the real #34
      scenario (6 concurrent processes x 120 lines each):

        keepFileOpen="true" (NLog's DEFAULT) ............ ~70 lines lost, silently
        keepFileOpen="false", no RetryingWrapper ........ ~1-3 lines lost, silently
        keepFileOpen="false" + RetryingWrapper (shipped)  0 lines lost

      NLog reports none of those losses — not even to its own internal log — so a drop here is as
      invisible as the old catch{} was. retryCount/retryDelayMilliseconds mirror what SafeFileAppend
      did by hand: a short bounded retry to ride out a sibling process's in-flight append or an AV
      scan.
    -->
    <target name="appfile" xsi:type="RetryingWrapper" retryCount="5" retryDelayMilliseconds="20">
      <!--
      keepFileOpen="false" is the load-bearing setting, and the successor to the FileShare fix that
      #34 ("AppLog silently drops lines") bought with real debugging time. Sibling ChargeKeeper
      processes — the ~288/day watchdog probes, a self-heal relaunch, an OnProcessExit handler racing
      the startup handoff — append to this same file concurrently. keepFileOpen="false" makes NLog
      open the file per write with a share mode that tolerates other writers and retry a collision,
      which is what the hand-rolled SafeFileAppend did with FileMode.Append + FileShare.ReadWrite.
      With the default keepFileOpen="true" NLog holds an exclusive handle and a sibling process's
      writes are lost — the exact #34 regression.

      NB: do NOT "restore" concurrentWrites="true" here. That was NLog 5's name for this behaviour;
      NLog 6 REMOVED the property, and an unknown attribute is silently ignored unless
      throwConfigExceptions is on — so it would look correct, do nothing, and lose lines again.
      NLogConfigTests loads this very file with throwConfigExceptions="true" and asserts these
      settings, so a typo or a stale-name attribute fails the build instead of failing in the field.

      The layout carries the #34-review lesson too: ${date} has NO culture= parameter because
      NLog's ${date} already defaults to InvariantCulture, and this timestamp is machine-facing log
      data that must stay Gregorian/ASCII on every locale. Do not "fix" the apparent omission by
      adding culture="" — an EMPTY culture makes NLog fall back to the thread's CurrentCulture,
      which stamps a non-Gregorian year (verified: 1448-02-03 under ar-SA), the very bug the review
      caught. culture=Invariant is not a thing and throws. NLogConfigTests renders this layout under
      ar-SA and asserts a Gregorian year, so either mistake fails the build.
      -->
      <target name="appfile_file"
              xsi:type="File"
              fileName="${specialfolder:folder=ApplicationData}\ChargeKeeper\app.log"
              keepFileOpen="false"
              createDirs="true"
              encoding="utf-8"
              writeBom="false"
              archiveAboveSize="10485760"
              maxArchiveDays="2"
              archiveSuffixFormat="_{1:yyyy-MM-dd}_{0:00}"
              lineEnding="LF"
              layout="[${date:format=yyyy-MM-dd HH\:mm\:ss zzz}] ${level:uppercase=true} ${message}&#10;" />
    </target>
  </targets>

  <rules>
    <logger name="*" minlevel="Info" writeTo="appfile" />
  </rules>
</nlog>
